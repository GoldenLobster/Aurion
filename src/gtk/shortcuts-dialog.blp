using Gtk 4.0;
using Adw 1;

Gtk.ShortcutsWindow shortcuts_dialog {

    Gtk.ShortcutsSection {
        title: C_("shortcut window", "General");

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Toggle primary menu");
            accelerator: "F10";
        }

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Copy song details to the clipboard");
            action-name: "win.copy";
        }

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Show shortcuts");
            action-name: "app.shortcuts";
        }

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Quit");
            action-name: "app.quit";
        }
    }

    Gtk.ShortcutsSection {
        title: C_("shortcut window", "Playlist");

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Add a song to the playlist");
            action-name: "queue.add-song";
        }

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Add a folder to the playlist");
            action-name: "queue.add-folder";
        }

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Clear the playlist");
            action-name: "queue.clear";
        }

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Toggle the playlist pane");
            action-name: "queue.toggle";
        }

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Toggle shuffling songs");
            action-name: "queue.shuffle";
        }
    }

    Gtk.ShortcutsSection {
        title: C_("shortcut window", "Playback");

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Toggle play/pause");
            action-name: "win.play";
        }

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Previous song");
            action-name: "win.previous";
        }

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Next song");
            action-name: "win.next";
        }

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Seek backwards in the current song");
            action-name: "win.seek-backwards";
        }

        Gtk.ShortcutsItem {
            title: C_("shortcut window", "Seek forward in the current song");
            action-name: "win.seek-forward";
        }
    }
}
