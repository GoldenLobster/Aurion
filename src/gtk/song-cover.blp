using Gtk 4.0;

template $AmberolSongCover: Widget {
  Box {
    halign: center;
    valign: center;

    Stack cover_stack {
      StackPage {
        name: "no-image";

        child: Image {
          overflow: hidden;
          icon-name: "folder-music-symbolic";
          pixel-size: 64;

          styles [
            "card",
            "dim-label",
          ]
        };
      }

      StackPage {
        name: "cover-image";

        child: $AmberolCoverPicture album_image {};
      }
    }
  }
}
