#: data/io.bassi.Amberol.desktop.in.in:2
#: data/io.bassi.Amberol.metainfo.xml.in.in:6
msgid "Amberol"
msgstr "Amberol"

#: data/io.bassi.Amberol.desktop.in.in:3
msgid "Music Player"
msgstr "Reproductor de musica"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/io.bassi.Amberol.desktop.in.in:11
msgid "music;player;media;audio;playlist;"
msgstr "musica;reproductor;medios;audio;lista de reproduction;"

#: data/io.bassi.Amberol.metainfo.xml.in.in:7
msgid "Plays music, and nothing else"
msgstr "Reproduce musica e nihil plus"

#: data/io.bassi.Amberol.metainfo.xml.in.in:9
msgid ""
"Amberol is a music player with no delusions of grandeur. If you just want to "
"play music available on your local system then Amberol is the music player "
"you are looking for."
msgstr ""
"Amberol es un reproductor de musica sin delusion de grandiositate. Si tu "
"solmente vole reproducer musica disponibile in tu systema local, alora "
"Amberol es le reproductor que tu sta cercante."

